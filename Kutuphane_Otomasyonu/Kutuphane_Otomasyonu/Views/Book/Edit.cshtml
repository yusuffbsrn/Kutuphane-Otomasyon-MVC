@model Kutuphane_Otomasyonu.Models.Book

<h2>Kitap Güncelle</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="BookId" /> <!-- ID gizli olarak gönder -->

    <div class="form-group">
        <label asp-for="Title"></label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="PageCount"></label>
        <input asp-for="PageCount" class="form-control" />
        <span asp-validation-for="PageCount" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="AuthorId"></label>
        <select asp-for="AuthorId" class="form-control">
            @foreach (dynamic author in ViewBag.Authors)
            {
                if (author.AuthorId == Model.AuthorId)
                {
                    <option value="@author.AuthorId" selected>@author.FullName</option>
                }
                else
                {
                    <option value="@author.AuthorId">@author.FullName</option>
                }
            }
        </select>
        <span asp-validation-for="AuthorId" class="text-danger"></span>
    </div>

    <div class="form-group form-check">
        <input type="checkbox" asp-for="IsAvailable" class="form-check-input" />
        <label asp-for="IsAvailable" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-primary">Güncelle</button>
</form>