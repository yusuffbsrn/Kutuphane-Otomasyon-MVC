@{
    ViewData[index: "Title"] = "Ana Sayfa";
}

<!-- Hero Section -->
<div class="hero-section mb-5" style="background: linear-gradient(135deg, #35a60f 0%, #2a8b0a 100%); color: white; padding: 80px 20px; border-radius: 10px; box-shadow: 0 4px 15px rgba(0,0,0,0.2);">
    <div class="text-center">
        <h1 class="display-3 fw-bold mb-3" style="text-shadow: 2px 2px 4px rgba(0,0,0,0.3);">
            <i class="bi bi-book-half"></i> Kütüphane Yönetim Sistemi
        </h1>
        <p class="lead mb-4" style="font-size: 1.3rem;">Eğitim ve Bilgiye Erişim İçin Dijital Çözüm</p>
        <button class="btn btn-light btn-lg me-2" onclick="window.location.href='/Book'">
            <i class="bi bi-search"></i> Kitapları Keşfet
        </button>
        <button class="btn btn-outline-light btn-lg" onclick="window.location.href='/Member'">
            <i class="bi bi-people"></i> Üyeler
        </button>
    </div>
</div>

<!-- Stats Section -->
<div class="row mb-5" style="background-color: #f8f9fa; padding: 40px 20px; border-radius: 10px;">
    <div class="col-md-3 text-center mb-3">
        <div style="font-size: 2.5rem; color: #35a60f; font-weight: bold;">
            <i class="bi bi-book"></i>
        </div>
        <h3 class="mt-2">Kitap Koleksiyonu</h3>
        <p class="text-muted">Geniş kitap yelpazesi</p>
    </div>
    <div class="col-md-3 text-center mb-3">
        <div style="font-size: 2.5rem; color: #35a60f; font-weight: bold;">
            <i class="bi bi-pencil-square"></i>
        </div>
        <h3 class="mt-2">Yazarlar</h3>
        <p class="text-muted">Çok sayıda yazar</p>
    </div>
    <div class="col-md-3 text-center mb-3">
        <div style="font-size: 2.5rem; color: #35a60f; font-weight: bold;">
            <i class="bi bi-people"></i>
        </div>
        <h3 class="mt-2">Üyeler</h3>
        <p class="text-muted">Etkin kullanıcı topluluğu</p>
    </div>
    <div class="col-md-3 text-center mb-3">
        <div style="font-size: 2.5rem; color: #35a60f; font-weight: bold;">
            <i class="bi bi-hand-thumbs-up"></i>
        </div>
        <h3 class="mt-2">Ödünç Sistemi</h3>
        <p class="text-muted">Pratik ve kolay</p>
    </div>
</div>

<!-- Features Section -->
<div class="mb-5">
    <h2 class="text-center mb-4 fw-bold" style="color: #35a60f; font-size: 2.5rem;">Özellikler</h2>
    <div class="row g-4">
        <div class="col-md-6">
            <div class="card border-0 shadow h-100" style="transition: transform 0.3s;border-left: 5px solid #35a60f;">
                <div class="card-body p-4">
                    <div style="font-size: 2.5rem; color: #35a60f; margin-bottom: 15px;">
                        <i class="bi bi-database"></i>
                    </div>
                    <h5 class="card-title fw-bold">Kapsamlı Kitap Veritabanı</h5>
                    <p class="card-text">Tüm kitapları kategoriye göre organize edilmiş, arama yapılabilir veritabanında bulunur.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow h-100" style="transition: transform 0.3s;border-left: 5px solid #35a60f;">
                <div class="card-body p-4">
                    <div style="font-size: 2.5rem; color: #35a60f; margin-bottom: 15px;">
                        <i class="bi bi-person-check"></i>
                    </div>
                    <h5 class="card-title fw-bold">Üyelik Yönetimi</h5>
                    <p class="card-text">Kolay üyelik kaydı ve yönetimi, üyelerinizin profil bilgilerini güncelleyebilirsiniz.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow h-100" style="transition: transform 0.3s;border-left: 5px solid #35a60f;">
                <div class="card-body p-4">
                    <div style="font-size: 2.5rem; color: #35a60f; margin-bottom: 15px;">
                        <i class="bi bi-arrow-left-right"></i>
                    </div>
                    <h5 class="card-title fw-bold">Ödünç Takibi</h5>
                    <p class="card-text">Kitap ödünç ve geri alım işlemlerini kolayca izleyin ve yönetin.</p>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card border-0 shadow h-100" style="transition: transform 0.3s;border-left: 5px solid #35a60f;">
                <div class="card-body p-4">
                    <div style="font-size: 2.5rem; color: #35a60f; margin-bottom: 15px;">
                        <i class="bi bi-pen"></i>
                    </div>
                    <h5 class="card-title fw-bold">Yazar Bilgisi</h5>
                    <p class="card-text">Yazarlar hakkında detaylı bilgiye ulaşın ve onların eserlerini keşfedin.</p>
                </div>
            </div>
        </div>
    </div>
</div>


