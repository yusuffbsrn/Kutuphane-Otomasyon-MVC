@model List<Kutuphane_Otomasyonu.Models.Member>
<h2>Üye Listesi</h2>
<a asp-action="Create" class="btn btn-primary">Yeni Üye Ekle</a>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>Email</th>
            <th>Kayıt Tarihi</th>
            <th>Durum</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
@foreach (Member item in Model)
{
    <tr>
        <td>@item.MemberId</td>
        <td>@item.FullName</td>
        <td>@item.Phone</td>
        <td>@item.Email</td>
        <td>@item.RegisterDate.ToString("dd.MM.yyyy")</td>
        <td>@(item.IsActive ? "Aktif" : "Pasif")</td>
        <td>
            <a asp-action="Edit" asp-route-id="@item.MemberId" class="btn btn-warning">Düzenle</a>
            <a asp-action="Delete" asp-route-id="@item.MemberId" class="btn btn-danger">Sil</a>
        </td>
    </tr>
}
    </tbody>
</table>
