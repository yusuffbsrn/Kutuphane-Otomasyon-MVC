@model Kutuphane_Otomasyonu.Models.Borrow

<h2>Ödünç Kaydını Düzenle</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="BorrowId" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="form-group">
        <label asp-for="BookId"></label>
        <select asp-for="BookId" class="form-control">
            <option value="">Kitap Seç</option>
            @foreach (dynamic book in ViewBag.Books)
            {
                if (book.BookId == Model.BookId)
                {
                    <option value="@book.BookId" selected>@book.Title</option>
                }
                else
                {
                    <option value="@book.BookId">@book.Title</option>
                }
            }
        </select>
        <span asp-validation-for="BookId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="MemberId"></label>
        <select asp-for="MemberId" class="form-control">
            <option value="">Üye Seç</option>
            @foreach (dynamic member in ViewBag.Members)
            {
                if (member.MemberId == Model.MemberId)
                {
                    <option value="@member.MemberId" selected>@member.FullName</option>
                }
                else
                {
                    <option value="@member.MemberId">@member.FullName</option>
                }
            }
        </select>
        <span asp-validation-for="MemberId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="BorrowDate"></label>
        <input asp-for="BorrowDate" class="form-control" type="date" />
        <span asp-validation-for="BorrowDate" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ReturnDate"></label>
        <input asp-for="ReturnDate" class="form-control" type="date" />
        <span asp-validation-for="ReturnDate" class="text-danger"></span>
    </div>

    <div class="form-group form-check">
        <input asp-for="IsReturned" class="form-check-input" />
        <label asp-for="IsReturned" class="form-check-label"></label>
    </div>

    <button type="submit" class="btn btn-success">Güncelle</button>
</form>